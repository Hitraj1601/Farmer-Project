# Frontend (Vite)
# NOTE: Vite only exposes variables prefixed with VITE_

# Backend API base URL
# - Local dev: you can keep this unset and rely on Vite proxy to /api (see vite.config.js)
# - Production: set to your deployed backend URL, including /api
VITE_API_URL=http://localhost:5000/api

# Razorpay public key (safe to expose in frontend)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
